generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         UserRole @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Room {
  id String @id @default(cuid())

  name String
  code String @unique

  cabinets Cabinet[]

  createdAt DateTime @default(now())
}

model Cabinet {
  id String @id @default(cuid())

  roomId String
  room   Room   @relation(fields: [roomId], references: [id], onDelete: Cascade)

  name  String
  code  String
  items Item[]

  createdAt DateTime @default(now())

  @@unique([roomId, code])
  @@index([roomId])
}

model Item {
  id String @id @default(cuid())

  name String

  image String?

  cabinetId String

  cabinet Cabinet     @relation(fields: [cabinetId], references: [id], onDelete: Cascade)
  images  ItemImage[]

  activityLogs ActivityLog[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  @@index([cabinetId])
  @@index([name])
}

model ItemImage {
  id String @id @default(cuid())

  itemId String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  path String

  createdAt DateTime @default(now())

  @@index([itemId])
}

model ActivityLog {
  id String @id @default(cuid())

  actorName String?

  itemId String?

  item Item? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  action String

  details String?

  createdAt DateTime @default(now())

  @@index([itemId])
  @@index([createdAt])
}
